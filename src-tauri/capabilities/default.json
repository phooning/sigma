{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:allow-write-text-file",
    "os:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "gpu-info",
          "cmd": "system_profiler",
          "args": ["SPDisplaysDataType", "-json"]
        },
        {
          "name": "gpu-usage",
          "cmd": "ioreg",
          "args": ["-l", "-w", "0", "-c", "AGXStatistics"]
        }
      ]
    },
    "core:window:default",
    "core:event:default"
  ]
}
