{
  "name": "sigma",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "lint": "pnpm exec biome check",
    "lint:apply": "pnpm exec biome check --fix",
    "bench": "node ./scripts/run-vitest-benchmarks.mjs",
    "bench:update": "node ./scripts/run-vitest-benchmarks.mjs --update-baseline",
    "bench:check": "pnpm bench && node ./scripts/check-vitest-bench-baseline.mjs",
    "bench:ipc:rust": "cargo bench --manifest-path src-tauri/Cargo.toml --bench ipc_latency",
    "check": "./.githooks/pre-push",
    "tauri": "tauri",
    "pw:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.2",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@webgpu/types": "^0.1.69",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.5"
  }
}
